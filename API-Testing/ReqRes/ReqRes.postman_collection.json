  "item": [
    {
      "name": "GET List Users",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const jsonData = pm.response.json();\r",
              "\r",
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Response time is less than 1000ms\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(1000);\r",
              "});\r",
              "\r",
              "pm.test(\"Data types are correct\", function () {\r",
              "    pm.expect(jsonData.page).to.be.a(\"number\");\r",
              "    pm.expect(jsonData.data).to.be.an(\"array\");\r",
              "});\r",
              "\r",
              "pm.test(\"Each user has required fields\", function () {\r",
              "    jsonData.data.forEach(function (user) {\r",
              "        pm.expect(user).to.have.property(\"id\");\r",
              "        pm.expect(user).to.have.property(\"email\");\r",
              "        pm.expect(user).to.have.property(\"first_name\");\r",
              "        pm.expect(user).to.have.property(\"last_name\");\r",
              "    });\r",
              "});\r",
              "\r",
              "pm.test(\"Data length matches per_page\", function () {\r",
              "    pm.expect(jsonData.data.length).to.eql(jsonData.per_page);\r",
              "});\r",
              "\r",
              "pm.test(\"Response has pagination fields\", function () {\r",
              "    pm.expect(jsonData).to.have.property(\"page\");\r",
              "    pm.expect(jsonData).to.have.property(\"total_pages\");\r",
              "    pm.expect(jsonData).to.have.property(\"per_page\");\r",
              "});\r",
              "\r",
              "pm.test(\"Total pages calculated correctly\", function () {\r",
              "    const expectedTotalPages = Math.ceil(jsonData.total / jsonData.per_page);\r",
              "\r",
              "    pm.expect(jsonData.total_pages).to.eql(expectedTotalPages);\r",
              "});\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseURL}}/api/users?page=2",
          "host": [
            "{{baseURL}}"
          ],
          "path": [
            "api",
            "users"
          ],
          "query": [
            {
              "key": "page",
              "value": "2"
            }
          ]
        }
      },
      "response": []
